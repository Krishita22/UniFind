{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "UniFind Flutter (Web)",
            "type": "dart",
            "request": "launch",
            "program": "unifind_flutter/lib/main.dart",
            "args": ["-d", "chrome"],
            "cwd": "${workspaceFolder}/unifind_flutter"
        },
        {
            "name": "UniFind Flutter (Mobile)",
            "type": "dart",
            "request": "launch",
            "program": "unifind_flutter/lib/main.dart",
            "cwd": "${workspaceFolder}/unifind_flutter"
        },
        {
            "name": "Launch Edge",
            "request": "launch",
            "type": "msedge",
            "url": "http://localhost:8080",
            "webRoot": "${workspaceFolder}"
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Launch Program",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "program": "${workspaceFolder}\\src\\components\\Home.tsx",
            "outFiles": [
                "${workspaceFolder}/**/*.js"
            ]
        }
    ]
}