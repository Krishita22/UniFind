# UniFind Django Backend .gitignore

# Virtual environment — never commit this, it's huge and machine-specific
venv/
env/
.venv/

# THESE TWO FILES CONTAIN YOUR GOOGLE OAUTH CREDENTIALS
# If either of these ends up on GitHub your Google account is in danger.
# They are in this gitignore. Please do not manually add them to git.
credentials.json
token.json

# Django debug database (SQLite — we use MySQL but Django sometimes creates this)
db.sqlite3

# Python cache files — generated automatically, not needed in git
__pycache__/
*.py[cod]
*$py.class
*.pyc

# Media uploads (uploaded images etc) — too large for git
media/

# VS Code settings — optional, uncomment if you don't want to share these
# .vscode/

# macOS metadata files — irrelevant to everyone who isn't on a Mac
.DS_Store

# Environment variable files (if you ever use one)
.env
.env.local
